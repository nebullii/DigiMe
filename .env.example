# Runtime
DIGIME_ENV=development
DIGIME_DRAFT_ONLY=true

# Local model
DIGIME_LLM_PROVIDER=ollama
DIGIME_LLM_MODEL=qwen3:latest
DIGIME_LLM_BASE_URL=http://127.0.0.1:11434

# Slack
SLACK_BOT_TOKEN=
SLACK_USER_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_YOUR_USER_ID=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_DEFAULT_CHANNEL_ID=
DISCORD_CHANNEL_IDS=

# Calendar provider
DIGIME_CALENDAR_PROVIDER=google

# Google Calendar / Meet
GOOGLE_CALENDAR_ID=primary
GOOGLE_OAUTH_CLIENT_FILE=./config/google-oauth-client.json
GOOGLE_OAUTH_TOKEN_FILE=./config/google-token.json
DIGIME_TIMEZONE=America/New_York

# Storage
DIGIME_DATABASE_URL=sqlite:///./digime.sqlite3
DIGIME_VECTOR_DIR=./data/processed/vector
